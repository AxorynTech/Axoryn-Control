{
  "expo": {
    "name": "Axoryn Control",
    "slug": "axoryn-control",
    "owner": "axoryntech",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "axoryn",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a2a3a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.axoryn.control",
      "buildNumber": "17",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "O Axoryn Control precisa de acesso à câmera para permitir que você leia códigos de barras de produtos no PDV e capture fotos de documentos para os registros e cadastros.",
        "NSPhotoLibraryUsageDescription": "O Axoryn Control precisa acessar sua galeria de fotos para que você possa selecionar e anexar imagens de documentos aos perfis de clientes e atualizar fotos do inventário."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a2a3a"
      },
      "package": "com.axoryn.control",
      "versionCode": 17,
      "softwareKeyboardLayoutMode": "pan",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icon.png",
          "color": "#1a2a3a",
          "defaultChannel": "default"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "react-native-fbsdk-next",
        {
          "appID": "1652425572435939",
          "clientToken": "653db828caeb16aac0bdefe262aa777a",
          "displayName": "Axoryn Control",
          "advertiserIDCollectionEnabled": true,
          "autoLogAppEventsEnabled": true
        }
      ],
      "expo-tracking-transparency"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b5a2c5c5-e3ec-42a5-adf6-f067f56b4489"
      }
    }
  }
}